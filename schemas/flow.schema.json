{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flux7.art/schemas/flow.schema.json",
  "title": "Flow Declaration",
  "description": "Declares an agent workflow as an ordered chain of steps",
  "type": "object",
  "required": ["flow"],
  "properties": {
    "flow": {
      "type": "object",
      "required": ["id", "owner", "steps"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Unique flow identifier (kebab-case)"
        },
        "name": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "description": "Event that initiates this flow"
        },
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"],
          "default": "internal"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "description": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["agent", "action"],
            "properties": {
              "agent": {
                "type": "string",
                "description": "Agent ID to execute this step"
              },
              "action": {
                "type": "string",
                "description": "Action the agent performs"
              },
              "inputs": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Named outputs from previous steps"
              },
              "outputs": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Named outputs this step produces"
              },
              "condition": {
                "type": "string",
                "description": "Expression that must be true to execute this step"
              },
              "requires_approval": {
                "type": "boolean",
                "default": false
              },
              "timeout_seconds": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    }
  }
}
